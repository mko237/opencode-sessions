{
  "knowledge": { "enabled": true },
  "curator": {
    "enabled": true, 
    "onIdle": true,
    "afterTurns": 10,
    "maxEntries": 25
  },
  "agentsFile": {
    "enabled": true,
    "path": "AGENTS.md" 
  },
  "budget": {
    "distilled": 0.20,
    "raw": 0.5,
    "output": 0.20,
    "ltm": 0.10
  },
  "distillation": {
    "minMessages": 8,
    "maxSegment": 50
  },
  "pruning": {
    "retention": 120,
    "maxStorage": 1024
  },
  "crossProject": true
}
