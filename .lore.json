{
  "knowledge": { "enabled": true },
  "curator": {
    "enabled": true, 
    "onIdle": true,
    "afterTurns": 20,
    "maxEntries": 45
  },
  "agentsFile": {
    "enabled": false,
    "path": "AGENTS.md" 
  },
  "budget": {
    "distilled": 0.15,
    "raw": 0.68,
    "output": 0.10,
    "ltm": 0.05
  },
  "distillation": {
    "minMessages": 20,
    "maxSegment": 100,
    "metaThreshold": 20
  },
  "pruning": {
    "retention": 120,
    "maxStorage": 1024
  },
  "crossProject": false
}
